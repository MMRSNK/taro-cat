# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Threads (Meta) Graph API ────────────────────────────
# See workflows/setup_threads_api.md for how to obtain these.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── Image hosting ───────────────────────────────────────
# Threads needs the forecast image at a public URL. Default host = catbox.moe
# (no account, no key). Options: catbox | tmpfiles | imgur
IMAGE_HOST=catbox
# Only needed if IMAGE_HOST=imgur
IMGUR_CLIENT_ID=

# ── Bot behavior ────────────────────────────────────────
# Cron for the daily general post (min hour dom mon dow). Default: 09:00 daily.
POST_CRON=0 9 * * *
# How often to poll for new @mentions, in minutes.
MENTION_POLL_MINUTES=5
# Probability (0..1) that a drawn card is reversed.
REVERSED_PROB=0.5
# Forecast language.
FORECAST_LANG=uk
# Timezone (affects POST_CRON). e.g. Europe/Kyiv
TZ=Europe/Kyiv

# Secrets — NEVER commit
.env
token.json
credentials.json

# Scratch / generated
.tmp/
.tmp_rules.txt
data/state.json
data/prompts.log

# Card scans are user-supplied; keep placeholders out of git by default.
# Comment the next line if you want real scans tracked in the repo.
cards/*.png

# Large deck image working folders (raw scans, crops, HQ output)
images-raw/
images-final/
images-final-hq/

# Firebase AI (Node upscaler) — config holds the API key, never commit
tools/upscale/node_modules/
tools/upscale/firebase-config.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db
